# =============================================================================
# GenAI Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- LLM Provider (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- PostgreSQL (Supabase hosted) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_DB=postgres
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:your-supabase-db-password@db.your-project.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (Vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pdf_chunks

# --- Neo4j (Graph DB) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret_2024

# --- JWT Secret (for gateway auth) ---
JWT_SECRET=change-me-to-a-random-64-char-string

# --- Search API (for Research Service) ---
TAVILY_API_KEY=
SERPER_API_KEY=

# --- Service Ports ---
GATEWAY_PORT=8000
RAG_SERVICE_PORT=8001
ATS_SERVICE_PORT=8002
RESEARCH_SERVICE_PORT=8003
SQL_SERVICE_PORT=8004
